# ═══════════════════════════════════════════════════════════════
# SubSentinel — Master Environment Variables
# REAL-TIME ONLY: All data comes from live services
# NO MOCK DATA — NO HYBRID MODE — 100% REAL
#
# Copy this file to backend/.env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── AWS Core ───────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ─── Amazon Bedrock (Claude Sonnet 4.5 — Latest) ───────────
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.3
BEDROCK_TOP_P=0.9

# ─── Amazon DynamoDB ────────────────────────────────────────
SUBSCRIPTIONS_TABLE=subsentinel-subscriptions
INSIGHTS_TABLE=subsentinel-insights
NEGOTIATIONS_TABLE=subsentinel-negotiations
DARK_PATTERNS_TABLE=subsentinel-dark-patterns
OUTCOMES_TABLE=subsentinel-outcomes

# ─── Amazon S3 ──────────────────────────────────────────────
RECEIPTS_BUCKET=subsentinel-receipts
SCREENSHOTS_BUCKET=subsentinel-screenshots

# ─── Amazon SNS (Notifications & Alerts) ────────────────────
# Created by CDK: infrastructure/lib/sns-stack.ts
SNS_NOTIFICATIONS_TOPIC_ARN=arn:aws:sns:REGION:ACCOUNT:subsentinel-notifications
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:REGION:ACCOUNT:subsentinel-alerts
SNS_STEPFUNCTIONS_TOPIC_ARN=arn:aws:sns:REGION:ACCOUNT:subsentinel-stepfunctions-notifications

# ─── Amazon SES (Email Ingestion) ──────────────────────────
# Created by CDK: infrastructure/lib/ses-stack.ts
# Setup: Verify your domain/email in SES console first
SES_RULE_SET_NAME=subsentinel-receipt-rules
SES_CONFIG_SET_NAME=subsentinel-email-tracking
SES_VERIFIED_EMAIL=receipts@yourdomain.com
SES_VERIFIED_DOMAIN=yourdomain.com

# ─── AWS Secrets Manager (OAuth Credentials) ───────────────
# Created by CDK: infrastructure/lib/secrets-stack.ts
# Update secrets in AWS Console after deployment
SECRETS_GMAIL_OAUTH_ARN=arn:aws:secretsmanager:REGION:ACCOUNT:secret:SubSentinel/GmailOAuth
SECRETS_CALENDAR_OAUTH_ARN=arn:aws:secretsmanager:REGION:ACCOUNT:secret:SubSentinel/CalendarOAuth
SECRETS_BEDROCK_CONFIG_ARN=arn:aws:secretsmanager:REGION:ACCOUNT:secret:SubSentinel/BedrockAPI

# ─── Amazon Cognito ─────────────────────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=

# ─── Amazon OpenSearch Serverless (Vector Search) ──────────
# Created by CDK: infrastructure/lib/database-stack.ts
OPENSEARCH_ENDPOINT=https://your-collection-id.REGION.aoss.amazonaws.com
OPENSEARCH_COLLECTION_NAME=subsentinel-vectors
OPENSEARCH_INDEX=subsentinel-outcomes

# ─── AWS KMS ────────────────────────────────────────────────
KMS_KEY_ID=
KMS_KEY_ALIAS=alias/subsentinel-master

# ═══════════════════════════════════════════════════════════════
# GOOGLE OAUTH 2.0 — REAL-TIME DATA
# ═══════════════════════════════════════════════════════════════
#
# Setup Steps:
#   1. Go to https://console.cloud.google.com
#   2. Create project: "SubSentinel-Demo"
#   3. Enable: Gmail API + Google Calendar API
#   4. Go to "APIs & Services" > "Credentials"
#   5. Create OAuth 2.0 Client ID (type: Desktop app)
#   6. Copy Client ID and Client Secret below
#   7. Run: cd backend && go run cmd/oauth/main.go
#   8. Authorize in browser with YOUR Google account
#   9. Copy the refresh token printed to terminal below
#
# ─── Google OAuth Client Credentials ───────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ─── Gmail OAuth (Real-Time Receipts) ──────────────────────
GMAIL_REFRESH_TOKEN=your-refresh-token-here
GMAIL_FETCH_QUERY=from:(netflix OR spotify OR adobe OR hulu OR nytimes) subject:(receipt OR invoice OR payment OR billing)
GMAIL_FETCH_DAYS=30

# ─── Google Calendar OAuth (Real-Time Life Events) ─────────
CALENDAR_REFRESH_TOKEN=your-refresh-token-here
CALENDAR_LOOKAHEAD_DAYS=90

# ─── TOON Configuration ────────────────────────────────────
TOON_ENABLED=true
TOON_LOG_SAVINGS=true
TOON_COMPRESS_DYNAMO=true
TOON_COMPRESS_OPENSEARCH=true

# ─── Application Settings ──────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=info
APP_NAME=subsentinel

# ─── Lambda Agent Settings ─────────────────────────────────
AUDITOR_MEMORY_MB=128
AUDITOR_TIMEOUT_SEC=30
CALENDAR_MEMORY_MB=128
CALENDAR_TIMEOUT_SEC=30
NEGOTIATOR_MEMORY_MB=256
NEGOTIATOR_TIMEOUT_SEC=60
DEFENDER_MEMORY_MB=512
DEFENDER_TIMEOUT_SEC=120
LEARNER_MEMORY_MB=256
LEARNER_TIMEOUT_SEC=45

# ─── Amazon Bedrock Region ─────────────────────────────────
BEDROCK_REGION=us-east-1

# ─── Amazon API Gateway ───────────────────────────────────
API_GATEWAY_ENDPOINT=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod
API_GATEWAY_STAGE=prod

# ─── Amazon Rekognition ──────────────────────────────────
REKOGNITION_REGION=us-east-1
REKOGNITION_MIN_CONFIDENCE=80

# ─── Amazon Comprehend ───────────────────────────────────
COMPREHEND_REGION=us-east-1

# ─── Amazon Textract ─────────────────────────────────────
TEXTRACT_REGION=us-east-1

# ─── Privacy / GDPR Compliance ───────────────────────────
AUDIT_TABLE=subsentinel-audit-log
PRIVACY_CASCADE_ENABLED=true
DATA_RETENTION_DAYS=365
PII_ENCRYPTION_ENABLED=true

# ─── CloudWatch Monitoring ───────────────────────────────
# Created by CDK: infrastructure/lib/monitoring-stack.ts
CLOUDWATCH_LOG_GROUP=/aws/subsentinel/backend
CLOUDWATCH_DASHBOARD_NAME=SubSentinel-Production
CLOUDWATCH_METRICS_ENABLED=true
CLOUDWATCH_METRICS_NAMESPACE=SubSentinel/TOON

# ─── AWS Step Functions ──────────────────────────────────
STEP_FUNCTIONS_ARN=arn:aws:states:REGION:ACCOUNT:stateMachine:subsentinel-orchestrator

# ─── Dark Pattern Taxonomy ───────────────────────────────
TAXONOMY_PATH=configs/taxonomy.toon

# ─── Learner Agent ───────────────────────────────────────
DECAY_HALF_LIFE_DAYS=30

# ═══════════════════════════════════════════════════════════════
# CDK DEPLOYMENT OUTPUTS
# After running: cd infrastructure && cdk deploy --all
# Copy these values from CloudFormation outputs
# ═══════════════════════════════════════════════════════════════

# From SubSentinel-SNS stack:
# - SubSentinel-SNS-Notifications
# - SubSentinel-SNS-Alerts
# - SubSentinel-SNS-StepFunctions

# From SubSentinel-SES stack:
# - SubSentinel-SES-RuleSet
# - SubSentinel-SES-ConfigSet

# From SubSentinel-Secrets stack:
# - SubSentinel-Secret-GmailOAuth
# - SubSentinel-Secret-CalendarOAuth
# - SubSentinel-Secret-BedrockConfig

# From SubSentinel-Database stack:
# - SubSentinel-OpenSearch-Endpoint

# From SubSentinel-Monitoring stack:
# - SubSentinel-DashboardUrl

# ═══════════════════════════════════════════════════════════════
# END OF CONFIGURATION
# ═══════════════════════════════════════════════════════════════